# AutoSME configuration

# Core
AUTOSME_API_KEY=your-secret-key
AUTOSME_ENV=production
AUTOSME_PORT=8000
AUTOSME_CORS_ORIGINS=*

# Database
DATABASE_URL=sqlite:///data/app.db
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost/dbname

# Redis (optional)
REDIS_URL=redis://redis:6379/0

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
