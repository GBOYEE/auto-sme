# AutoSME Environment Configuration
# Copy to .env and fill in values

# Required: Secret for API authentication
AUTOSME_API_KEY=your-secret-key-here

# Environment: production or development
AUTOSME_ENV=production

# Database URL (PostgreSQL)
# For local: postgresql://auto_sme:auto_sme@localhost:5432/auto_sme
# Railway provides DATABASE_URL automatically if you add Postgres addon
DATABASE_URL=

# CORS: comma-separated allowed origins (or * for all)
AUTOSME_CORS_ORIGINS=https://yourdomain.com

# Redis URL (optional, for caching/queue)
REDIS_URL=redis://localhost:6379/0

# Port (default 8000)
AUTOSME_PORT=8000

# Twilio WhatsApp webhook secret (if using WhatsApp integration)
TWILIO_AUTH_TOKEN=
